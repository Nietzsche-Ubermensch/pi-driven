{
  "name": "pi-driven",
  "version": "0.1.0",
  "private": true,
  "description": "Enterprise-grade pi distribution — AI-native development with full pipeline automation",
  "license": "MIT",
  "author": "Nietzsche-Ubermensch",
  "type": "module",
  "scripts": {
    "build": "tsc -p packages/core/tsconfig.json --skipLibCheck && tsc -p packages/cli/tsconfig.json --skipLibCheck",
    "dev": "turbo run dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "turbo run typecheck",
    "changelog": "git cliff -o CHANGELOG.md",
    "changelog:preview": "git cliff --unreleased",
    "release": "git cliff -o CHANGELOG.md && node scripts/bump-version.mjs",
    "release:patch": "npm run release patch",
    "release:minor": "npm run release minor",
    "release:major": "npm run release major",
    "prepare": "husky",
    "clean": "turbo run clean && rm -rf node_modules",
    "setup": "node scripts/setup.mjs"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^19.0.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "turbo": "^2.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
