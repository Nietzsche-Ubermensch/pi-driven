{
  "name": "pi-driven-deployment-monitor",
  "description": "Recurrence trigger → poll GitHub Actions runs → notify on failure → orchestrate rollback",
  "triggers": [
    {
      "type": "recurrence",
      "interval": 5,
      "frequency": "minute"
    }
  ],
  "steps": [
    {
      "name": "Fetch Recent Workflow Runs",
      "connector": "github",
      "operation": "list_workflow_runs",
      "inputs": {
        "owner": "Nietzsche-Ubermensch",
        "repo": "pi-driven",
        "per_page": 10
      }
    },
    {
      "name": "Filter Failed Deployments",
      "action": "filter_array",
      "inputs": {
        "source": "@{body('Fetch_Recent_Workflow_Runs')?.['workflow_runs']}",
        "condition": "@{and(equals(item()?.['status'], 'completed'), equals(item()?.['conclusion'], 'failure'))}"
      },
      "output": "failedRuns"
    },
    {
      "name": "For Each Failure — Notify",
      "action": "apply_to_each",
      "inputs": {
        "source": "@{body('Filter_Failed_Deployments')}"
      },
      "actions": [
        {
          "name": "Post to Teams",
          "connector": "teams",
          "operation": "post_message",
          "inputs": {
            "channel": "pi-driven-alerts",
            "message": "⚠ Deployment failed: @{item()?.['name']}\nBranch: @{item()?.['head_branch']}\nURL: @{item()?.['html_url']}"
          }
        },
        {
          "name": "Check for Rollback — Last Known Good Tag",
          "connector": "github",
          "operation": "list_tags",
          "inputs": {
            "owner": "Nietzsche-Ubermensch",
            "repo": "pi-driven",
            "per_page": 5
          }
        },
        {
          "name": "Trigger Rollback Flow",
          "action": "http",
          "condition": "@{greater(length(body('Check_for_Rollback')?.['tags']), 0)}",
          "inputs": {
            "method": "POST",
            "uri": "https://prod-xx.westus.logic.azure.com/workflows/rollback/triggers/manual/invoke",
            "body": {
              "failed_run": "@{item()?.['id']}",
              "last_good_tag": "@{first(body('Check_for_Rollback')?.['tags'])?.['name']}"
            }
          }
        }
      ]
    }
  ]
}
